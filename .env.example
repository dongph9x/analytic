# Copy file này thành .env và điền API key của bạn.
# Lấy key tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# (Tùy chọn) Để chức năng "Kiểm tra quy hoạch" tìm kiếm thực tế trên mạng (quyết định quy hoạch, cổng chính phủ).
# Lấy key miễn phí tại: https://serper.dev
# SERPER_API_KEY=...

# Bảo mật API: khi đặt mật khẩu, mọi gọi API (giá, tin tức, nhận định, kiểm tra quy hoạch) sẽ yêu cầu nhập pass một lần; session lưu 24h.
# API_AUTH_PASSWORD=your_secret_password
# (Tùy chọn) Secret cho session; nếu không đặt sẽ dùng API_AUTH_PASSWORD.
# SESSION_SECRET=another_random_secret
# API_AUTH_PASSWORD
